{
  "name": "@snsip/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for SNSIP-Agent — read .sol agent identities and permissions from any MCP client (Claude Desktop, Cursor, etc.)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "snsip-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@snsip/agent-sdk": "workspace:*",
    "@solana/web3.js": "^1.98.0",
    "tweetnacl": "^1.0.3",
    "bs58": "^6.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^20.0.0"
  }
}
